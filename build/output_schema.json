{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pocketop.app/schema/output_schema.json",
  "title": "PocketOP-Database assembled output registry",
  "description": "The authoritative field registry for the assembled published outputs. This file IS the registry: a field counts as added to an output kind only once it is listed under that kind's $def here. Every entry in an assembled output is validated against the $def for its kind. Each $def is closed at the entry top level (additionalProperties false), so any field not registered here is rejected. Every field is optional: nothing is marked required, so a historical entry that omits a field still validates. The two open objects (the cine sources object, and the fieldNotes objects) permit free string-valued keys internally; closedness applies only to the entry top level. Legacy union outputs (lenses.json, lens-details.json) and the ptz-details.json hyphen alias are out of scope and are not validated here. No em dashes appear in this file by project policy.",

  "$defs": {

    "lens_core": {
      "description": "LENS CORE. One registry shared by broadcast (broadcast_lenses.json) and cine (cine_lenses.json) core entries.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "manufacturer": { "type": "string" },
        "model": { "type": "string" },
        "series": { "type": "string" },
        "generation": { "enum": ["4K UHD", "HD", "SD", "Cinema", "Legacy", "8K"] },
        "focalLengthMin": { "type": "number" },
        "focalLengthMax": { "type": "number" },
        "zoomRatio": { "type": "number" },
        "extenderFactor": { "type": "number" },
        "sensorFormat": { "enum": ["twoThirdsInch", "halfInch", "oneThirdInch", "oneInch", "oneTwoPointEightInch", "superThirtyFive", "fullFrame", "largeFormat", "microFourThirds"] },
        "mount": { "enum": ["B4", "PL", "LPL", "EF", "RF", "L", "E"] },
        "isPTZ": { "type": "boolean" },
        "isFree": { "type": "boolean" },
        "isCustom": { "type": "boolean" },
        "notes": { "type": "string" },
        "addedDate": { "type": ["string", "null"] }
      }
    },

    "lens_details_broadcast": {
      "description": "LENS DETAILS, broadcast variant. Validated against entries whose lensType is broadcast (broadcast_lens_details.json). The broadcast sources value is an array of strings. weightG, lengthMm, closeFocusM, opticalElements and webSources are registered live fields. description is the registered user-facing prose field, a string or null. fieldNotes is an open object of string values, or null. apertureType accepts null, meaning not investigated. Cross-field invariant: a filterType of front_thread, screw_in or hood_thread implies filterThreadMm is a number or 'unknown'.",
      "type": "object",
      "additionalProperties": false,
      "allOf": [
        {
          "if": { "required": ["filterType"], "properties": { "filterType": { "enum": ["front_thread", "screw_in", "hood_thread"] } } },
          "then": { "required": ["filterThreadMm"], "properties": { "filterThreadMm": { "anyOf": [{ "type": "number" }, { "const": "unknown" }] } } }
        }
      ],
      "properties": {
        "id": { "type": "string" },
        "lensType": { "enum": ["broadcast", "cine"] },
        "filterType": { "anyOf": [{ "enum": ["front_thread", "matte_box", "internal", "none", "screw_in", "hood_thread"] }, { "type": "null" }] },
        "filterThreadMm": { "anyOf": [{ "type": ["number", "null"] }, { "const": "none" }, { "const": "unknown" }] },
        "hasServoZoom": { "type": ["boolean", "null"] },
        "hasServoFocus": { "type": ["boolean", "null"] },
        "servoConnector": { "anyOf": [{ "enum": ["12pin", "20pin", "none"] }, { "type": "null" }] },
        "formFactor": { "anyOf": [{ "enum": ["portable", "studio", "box"] }, { "type": "null" }] },
        "hasMacro": { "type": ["boolean", "null"] },
        "imageCircleMm": { "type": ["number", "null"] },
        "isParfocal": { "type": "null" },
        "hasFocusBreathing": { "type": "null" },
        "sources": { "type": "array", "items": { "type": "string" } },
        "fieldNotes": { "anyOf": [{ "type": "object", "additionalProperties": { "type": "string" } }, { "type": "null" }] },
        "maxApertureWide": { "anyOf": [{ "type": ["number", "null"] }, { "const": "unknown" }] },
        "maxApertureTele": { "anyOf": [{ "type": ["number", "null"] }, { "const": "unknown" }] },
        "apertureType": { "anyOf": [{ "enum": ["T", "f"] }, { "type": "null" }] },
        "hasIS": { "type": ["boolean", "null"] },
        "introductionYear": { "type": ["integer", "null"] },
        "frontDiameterMm": { "type": ["number", "null"] },
        "maximumDiameterMm": { "type": ["number", "null"] },
        "productUrl": { "type": ["string", "null"] },
        "manufacturerUrl": { "type": ["string", "null"] },
        "weightG": { "type": ["number", "null"] },
        "lengthMm": { "type": ["number", "null"] },
        "closeFocusM": { "type": ["number", "null"] },
        "opticalElements": { "anyOf": [{ "type": ["integer", "null"] }, { "const": "unknown" }] },
        "webSources": { "type": "array", "items": { "type": "string" } },
        "description": { "type": ["string", "null"] }
      }
    },

    "lens_details_cine": {
      "description": "LENS DETAILS, cine variant. Validated against entries whose lensType is cine (cine_lens_details.json). The cine sources value is an open object of string values. description is the registered user-facing prose field, a string or null. fieldNotes is a registered open object of string values. apertureType accepts null, meaning not investigated. tStop carries the cine T-stop at the wide end and tStopTele the T-stop at the tele end for ramping zooms; each is a number, null, or 'unknown'. hasIS marks built-in optical image stabilisation, a boolean or null. Cross-field invariant: a filterType of front_thread, screw_in or hood_thread implies filterThreadMm is a number or 'unknown'.",
      "type": "object",
      "additionalProperties": false,
      "allOf": [
        {
          "if": { "required": ["filterType"], "properties": { "filterType": { "enum": ["front_thread", "screw_in", "hood_thread"] } } },
          "then": { "required": ["filterThreadMm"], "properties": { "filterThreadMm": { "anyOf": [{ "type": "number" }, { "const": "unknown" }] } } }
        }
      ],
      "properties": {
        "id": { "type": "string" },
        "lensType": { "enum": ["broadcast", "cine"] },
        "manufacturerUrl": { "type": ["string", "null"] },
        "weightG": { "type": ["number", "null"] },
        "lengthMm": { "type": ["number", "null"] },
        "frontDiameterMm": { "type": ["number", "null"] },
        "closeFocusM": { "type": ["number", "null"] },
        "introductionYear": { "type": ["integer", "null"] },
        "imageCircleMm": { "type": ["number", "null"] },
        "opticalElements": { "anyOf": [{ "type": ["integer", "null"] }, { "const": "unknown" }] },
        "filterType": { "anyOf": [{ "enum": ["front_thread", "matte_box", "internal", "none", "screw_in", "hood_thread"] }, { "type": "null" }] },
        "filterThreadMm": { "anyOf": [{ "type": ["number", "null"] }, { "const": "none" }, { "const": "unknown" }] },
        "isParfocal": { "type": ["boolean", "null"] },
        "hasFocusBreathing": { "anyOf": [{ "enum": ["none", "minimal", "moderate", "significant", "unknown"] }, { "type": "null" }] },
        "hasFrontRotation": { "type": ["boolean", "null"] },
        "focusRingRotationDeg": { "type": ["number", "null"] },
        "gearPitch": { "anyOf": [{ "type": ["number", "null"] }, { "const": "none" }] },
        "sources": { "type": "object", "additionalProperties": { "type": "string" } },
        "webSources": { "type": "array", "items": { "type": "string" } },
        "maxApertureWide": { "anyOf": [{ "type": ["number", "null"] }, { "const": "unknown" }] },
        "maxApertureTele": { "anyOf": [{ "type": ["number", "null"] }, { "const": "unknown" }] },
        "apertureType": { "anyOf": [{ "enum": ["T", "f"] }, { "type": "null" }] },
        "tStop": { "anyOf": [{ "type": ["number", "null"] }, { "const": "unknown" }] },
        "tStopTele": { "anyOf": [{ "type": ["number", "null"] }, { "const": "unknown" }] },
        "hasIS": { "type": ["boolean", "null"] },
        "maximumDiameterMm": { "type": ["number", "null"] },
        "productUrl": { "type": ["string", "null"] },
        "description": { "type": ["string", "null"] },
        "fieldNotes": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },

    "ptz_core": {
      "description": "PTZ CORE (ptz_cameras.json). addedDate is a registered live field. Several numeric fields carry null for cameras still missing specs; null validates.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "sensorLabel": { "type": "string" },
        "sensorWidthMM": { "type": ["number", "null"] },
        "sensorHeightMM": { "type": ["number", "null"] },
        "minFocalLengthMM": { "type": ["number", "null"] },
        "maxFocalLengthMM": { "type": ["number", "null"] },
        "hFOVWide": { "type": ["number", "null"] },
        "hFOVTele": { "type": ["number", "null"] },
        "opticalZoom": { "type": ["integer", "null"] },
        "isFree": { "type": "boolean" },
        "isCustom": { "type": "boolean" },
        "notes": { "type": "string" },
        "addedDate": { "type": ["string", "null"] }
      }
    },

    "ptz_details": {
      "description": "PTZ DETAILS (ptz_details.json). The sources value is an array of strings. poeClass is a registered live string field. description is the registered user-facing prose field, a string or null. fieldNotes is a registered open object of string values. streamingProtocols and trackingDataOut are closed vocabulary array fields, or null; an unlisted value is rejected by the build. apertureType accepts null, meaning not investigated. introductionYear is an integer, null, or 'unknown'. isParfocal is retired as a PTZ field and no longer registered here.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "manufacturerUrl": { "type": ["string", "null"] },
        "controlProtocols": { "anyOf": [{ "type": "array", "items": { "type": "string" } }, { "type": "null" }] },
        "videoOutputs": { "anyOf": [{ "type": "array", "items": { "type": "string" } }, { "type": "null" }] },
        "hasPoE": { "type": ["boolean", "null"] },
        "presetCount": { "type": ["integer", "null"] },
        "panRangeDeg": { "type": ["number", "null"] },
        "tiltRangeDeg": { "type": ["number", "null"] },
        "maxPanSpeedDegS": { "type": ["number", "null"] },
        "maxTiltSpeedDegS": { "type": ["number", "null"] },
        "hasIR": { "type": ["boolean", "null"] },
        "whiteBalanceModes": { "anyOf": [{ "type": "array", "items": { "type": "string" } }, { "type": "null" }] },
        "minLux": { "type": ["number", "null"] },
        "weightG": { "type": ["number", "null"] },
        "widthMm": { "type": ["number", "null"] },
        "heightMm": { "type": ["number", "null"] },
        "depthMm": { "type": ["number", "null"] },
        "mountThreads": { "type": ["string", "null"] },
        "hasCeilingMount": { "type": ["boolean", "null"] },
        "hasWallMount": { "type": ["boolean", "null"] },
        "sources": { "type": "array", "items": { "type": "string" } },
        "maxApertureWide": { "anyOf": [{ "type": ["number", "null"] }, { "const": "unknown" }] },
        "maxApertureTele": { "anyOf": [{ "type": ["number", "null"] }, { "const": "unknown" }] },
        "apertureType": { "anyOf": [{ "enum": ["f", "T"] }, { "type": "null" }] },
        "hasIS": { "type": ["boolean", "null"] },
        "autoTracking": { "anyOf": [{ "enum": ["none", "basic", "ai", "external", "unknown"] }, { "type": "null" }] },
        "autoTrackingNote": { "type": ["string", "null"] },
        "hasND": { "type": ["boolean", "null"] },
        "ndDetail": { "type": ["string", "null"] },
        "introductionYear": { "anyOf": [{ "type": ["integer", "null"] }, { "const": "unknown" }] },
        "productUrl": { "type": ["string", "null"] },
        "poeClass": { "type": ["string", "null"] },
        "streamingProtocols": { "anyOf": [{ "type": "array", "items": { "enum": ["IP", "NDI", "NDI|HX", "NDI|HX2", "NDI|HX3", "SRT", "RTSP", "RTMP", "RTMPS", "HLS", "Dante AV-H", "SMPTE ST 2110"] } }, { "type": "null" }] },
        "trackingDataOut": { "anyOf": [{ "type": "array", "items": { "enum": ["FreeD"] } }, { "type": "null" }] },
        "description": { "type": ["string", "null"] },
        "fieldNotes": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    }

  }
}
